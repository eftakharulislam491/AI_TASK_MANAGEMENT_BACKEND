generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  MANAGER
  TEAM_LEADER
  MEMBER
}

enum UserType {
  ORGANIZATION
  MEMBER
}

enum JoinRequestType {
  REQUEST_TO_JOIN
  INVITATION
}

enum JoinRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELED
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  LEFT
}

enum AbilityLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum RoleChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_STATUS_CHANGED
  TASK_COMMENT
  TASK_DEADLINE_APPROACHING
  TASK_OVERDUE
  PROJECT_MEMBER_ADDED
  TEAM_MEMBER_ADDED
  INVITATION_RECEIVED
  ROLE_CHANGED
  MENTION
}

enum AttachmentEntityType {
  TASK
  COMMENT
  PROJECT
}

model User {
  id                    String   @id @default(cuid())
  email                 String   @unique
  firstName             String
  lastName              String
  displayName           String?
  type                  UserType
  role                  Role     @default(MEMBER)
  isActive              Boolean  @default(true)
  currentOrganizationId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  currentOrganization  Organization?            @relation("CurrentOrganization", fields: [currentOrganizationId], references: [id], onDelete: SetNull)
  credential           Credential?
  profile              UserProfile?
  abilities            UserAbility[]
  organizationsOwned   Organization[]           @relation("OrganizationOwner")
  memberships          OrganizationMembership[]
  joinRequestsSent     JoinRequest[]            @relation("JoinRequestSender")
  joinRequestsReceived JoinRequest[]            @relation("JoinRequestRecipient")
  requestedRoleChanges RoleChangeRequest[]      @relation("RoleChangeRequester")
  targetedRoleChanges  RoleChangeRequest[]      @relation("RoleChangeTarget")
  reviewedRoleChanges  RoleChangeRequest[]      @relation("RoleChangeReviewer")
  teamMemberships      TeamMember[]
  projectMemberships   ProjectMember[]
  teamsLed             Team[]                   @relation("TeamLeader")
  projectsOwned        Project[]                @relation("ProjectOwner")
  tasksAssigned        Task[]                   @relation("TaskAssignee")
  tasksReported        Task[]                   @relation("TaskReporter")
  comments             Comment[]
  attachments          Attachment[]
  activityLogs         ActivityLog[]
  notifications        Notification[]

  @@index([currentOrganizationId])
  @@index([email, role])
}

model Credential {
  id                String    @id @default(cuid())
  userId            String    @unique
  passwordHash      String    @map("password_hash")
  refreshTokenHash  String?   @map("refresh_token_hash")
  passwordChangedAt DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  ownerId     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner              User                     @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  currentUsers       User[]                   @relation("CurrentOrganization")
  memberships        OrganizationMembership[]
  joinRequests       JoinRequest[]
  roleChangeRequests RoleChangeRequest[]
  teams              Team[]
  projects           Project[]
  tasks              Task[]
  activityLogs       ActivityLog[]
  notifications      Notification[]
  documentEmbeddings DocumentEmbedding[]

  @@index([ownerId])
  @@index([name])
}

model UserProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  phone             String?
  headline          String?
  bio               String?
  dateOfBirth       DateTime?
  gender            String?
  addressLine1      String?
  addressLine2      String?
  city              String?
  state             String?
  country           String?
  postalCode        String?
  timezone          String?
  currentJobTitle   String?
  yearsOfExperience Int?
  totalProjects     Int?
  resumeUrl         String?
  portfolioUrl      String?
  websiteUrl        String?
  linkedinUrl       String?
  githubUrl         String?
  twitterUrl        String?
  socialLinks       Json?
  otherInfo         Json?
  aiMetadata        Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([city, country])
  @@index([currentJobTitle])
}

model UserAbility {
  id                String       @id @default(cuid())
  userId            String
  slug              String
  name              String
  category          String?
  proficiencyLevel  AbilityLevel @default(INTERMEDIATE)
  proficiencyScore  Int?
  yearsOfExperience Int?
  projectsCount     Int?
  isPrimary         Boolean      @default(false)
  notes             String?
  evidenceUrl       String?
  keywords          String[]     @default([])
  aiMetadata        Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
  @@index([userId, category])
  @@index([userId, proficiencyLevel])
}

model RoleChangeRequest {
  id             String                  @id @default(cuid())
  organizationId String?
  requesterId    String
  targetUserId   String
  currentRole    Role
  requestedRole  Role
  status         RoleChangeRequestStatus @default(PENDING)
  reason         String?
  reviewNote     String?
  metadata       Json?
  reviewedAt     DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  reviewerId     String?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  requester    User          @relation("RoleChangeRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  targetUser   User          @relation("RoleChangeTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  reviewer     User?         @relation("RoleChangeReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, requestedRole])
  @@index([requesterId, status])
  @@index([targetUserId, status])
  @@index([reviewerId, status])
}

model OrganizationMembership {
  id             String           @id @default(cuid())
  userId         String
  organizationId String
  role           Role             @default(MEMBER)
  status         MembershipStatus @default(ACTIVE)
  joinedAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId, role, status])
  @@index([userId, status])
}

model JoinRequest {
  id              String            @id @default(cuid())
  organizationId  String
  requesterId     String
  recipientId     String?
  type            JoinRequestType
  status          JoinRequestStatus @default(PENDING)
  message         String?
  invitationToken String?           @unique
  invitationEmail String?
  expiresAt       DateTime?
  respondedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requester    User         @relation("JoinRequestSender", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient    User?        @relation("JoinRequestRecipient", fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, type])
  @@index([requesterId, status])
  @@index([recipientId, status])
  @@index([invitationEmail, status])
}

model Team {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String
  description    String?
  leaderId       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leader       User?        @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  members      TeamMember[]
  projects     Project[]

  @@unique([organizationId, slug])
  @@index([organizationId, isActive])
  @@index([leaderId])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model Project {
  id             String        @id @default(cuid())
  organizationId String
  teamId         String?
  name           String
  slug           String
  description    String?
  status         ProjectStatus @default(ACTIVE)
  ownerId        String
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team?           @relation(fields: [teamId], references: [id], onDelete: SetNull)
  owner        User            @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members      ProjectMember[]
  tasks        Task[]
  attachments  Attachment[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([teamId])
  @@index([ownerId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model Task {
  id             String       @id @default(cuid())
  organizationId String
  projectId      String?
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  assigneeId     String?
  reporterId     String
  deadline       DateTime?
  estimatedHours Float?
  tags           String[]     @default([])
  aiMetadata     Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee     User?         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter     User          @relation("TaskReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  comments     Comment[]
  attachments  Attachment[]
  activities   ActivityLog[]

  @@index([organizationId, status, priority])
  @@index([projectId, status])
  @@index([assigneeId, status])
  @@index([reporterId])
  @@index([deadline])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task        Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  attachments Attachment[]

  @@index([taskId, createdAt])
  @@index([authorId])
}

model Attachment {
  id           String               @id @default(cuid())
  entityType   AttachmentEntityType
  taskId       String?
  commentId    String?
  projectId    String?
  uploadedById String
  fileName     String
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  task       Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  comment    Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([commentId])
  @@index([projectId])
  @@index([uploadedById])
}

model ActivityLog {
  id             String   @id @default(cuid())
  organizationId String
  taskId         String?
  projectId      String?
  actorId        String
  action         String
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  task         Task?        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor        User         @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([taskId, createdAt])
  @@index([projectId, createdAt])
  @@index([actorId])
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  organizationId String?
  type           NotificationType
  title          String
  body           String
  metadata       Json?
  isRead         Boolean          @default(false)
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([organizationId])
}

model DocumentEmbedding {
  id             String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String
  chunkKey       String                       @unique
  sourceType     String
  sourceId       String
  sourceLabel    String?
  content        String
  metadata       Json                         @default("{}")
  embedding      Unsupported("vector(1536)")?
  isDeleted      Boolean                      @default(false)
  deletedAt      DateTime?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, sourceType, isDeleted])
  @@index([sourceId])
  @@map("document_embeddings")
}
