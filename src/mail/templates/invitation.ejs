<!doctype html>
<html>
  <body style="margin:0;background:#f6f7fb;color:#111827;font-family:Arial,sans-serif">
    <span style="display:none">You have been invited to join <%= organizationName %>.</span>
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="padding:32px 16px">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:560px;background:#ffffff;border:1px solid #e5e7eb;border-radius:8px">
            <tr>
              <td style="padding:32px">
                <h1 style="font-size:24px;line-height:32px;margin:0 0 16px">Join <%= organizationName %></h1>
                <p style="font-size:15px;line-height:24px;color:#374151;margin:0 0 12px">
                  <% if (inviterName) { %><%= inviterName %> invited you to collaborate in <strong><%= organizationName %></strong>.<% } else { %>You have been invited to collaborate in <strong><%= organizationName %></strong>.<% } %>
                </p>
                <% if (message) { %>
                  <p style="font-size:15px;line-height:24px;color:#374151;margin:0 0 12px"><%= message %></p>
                <% } %>
                <% if (expiresAt) { %>
                  <p style="font-size:14px;line-height:22px;color:#6b7280;margin:0 0 20px">This invitation expires at <%= expiresAt %>.</p>
                <% } %>
                <p style="margin:28px 0">
                  <a href="<%= inviteUrl %>" style="background:#2563eb;color:#ffffff;text-decoration:none;padding:12px 18px;border-radius:6px;display:inline-block;font-weight:700">Accept invitation</a>
                </p>
                <p style="font-size:12px;line-height:18px;color:#6b7280;margin-top:28px"><%= appName %> notification</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
