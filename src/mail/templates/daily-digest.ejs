<!doctype html>
<html>
  <body style="margin:0;background:#f6f7fb;color:#111827;font-family:Arial,sans-serif">
    <span style="display:none">Daily task digest</span>
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="padding:32px 16px">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:640px;background:#ffffff;border:1px solid #e5e7eb;border-radius:8px">
            <tr>
              <td style="padding:32px">
                <h1 style="font-size:24px;line-height:32px;margin:0 0 16px">Daily task digest</h1>
                <% if (recipientName) { %>
                  <p style="font-size:15px;line-height:24px;color:#374151;margin:0 0 12px">Hi <%= recipientName %>, here is your task summary for today.</p>
                <% } else { %>
                  <p style="font-size:15px;line-height:24px;color:#374151;margin:0 0 12px">Here is your task summary for today.</p>
                <% } %>
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin:20px 0;border-collapse:collapse">
                  <tr>
                    <td style="padding:12px;border:1px solid #e5e7eb;font-size:14px;color:#374151"><strong><%= totalCount %></strong><br />Active tasks</td>
                    <td style="padding:12px;border:1px solid #e5e7eb;font-size:14px;color:#374151"><strong><%= overdueCount %></strong><br />Overdue</td>
                    <td style="padding:12px;border:1px solid #e5e7eb;font-size:14px;color:#374151"><strong><%= dueSoonCount %></strong><br />Due within 48h</td>
                  </tr>
                </table>
                <% tasks.forEach(function(task) { %>
                  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-top:1px solid #e5e7eb;padding:14px 0">
                    <tr>
                      <td>
                        <p style="font-size:16px;line-height:24px;color:#111827;margin:0 0 6px"><strong><%= task.title %></strong></p>
                        <p style="font-size:13px;line-height:20px;color:#6b7280;margin:0">
                          <%= task.status %> · <%= task.priority %>
                          <% if (task.projectName) { %> · <%= task.projectName %><% } %>
                          <% if (task.deadline) { %> · Deadline: <%= task.deadline %><% } %>
                          <% if (task.isOverdue) { %> · Overdue<% } %>
                        </p>
                      </td>
                      <% if (task.taskUrl) { %>
                        <td align="right" style="white-space:nowrap;padding-left:16px">
                          <a href="<%= task.taskUrl %>" style="font-size:13px;color:#2563eb;text-decoration:none;font-weight:700">Open</a>
                        </td>
                      <% } %>
                    </tr>
                  </table>
                <% }) %>
                <% if (dashboardUrl) { %>
                  <p style="margin:28px 0">
                    <a href="<%= dashboardUrl %>" style="background:#2563eb;color:#ffffff;text-decoration:none;padding:12px 18px;border-radius:6px;display:inline-block;font-weight:700">Open dashboard</a>
                  </p>
                <% } %>
                <p style="font-size:12px;line-height:18px;color:#6b7280;margin-top:28px"><%= appName %> notification</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
